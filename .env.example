# Copy to .env for local development. Do not commit .env to Git.
PORT=3000
NODE_ENV=development

# Optional: admin email for future campaign-request notifications
# ADMIN_EMAIL=you@example.com

DATABASE_URL="postgresql://user:password@localhost:5432/vybridge?schema=public"

STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Publishable (not secret) key — safe to expose client-side. Served to the
# browser via GET /api/config for the /slots checkout page's Stripe.js.
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Days after a deal's ends_at before the payout transfer is eligible to run.
# Buffer against disputes filed after the placement finished.
PAYOUT_BUFFER_DAYS=4

# Hours a creative can sit in pending_approval before it is auto-approved.
AUTO_APPROVE_HOURS=48
