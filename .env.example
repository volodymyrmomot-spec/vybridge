# Copy to .env for local development. Do not commit .env to Git.
PORT=3000
NODE_ENV=development

# Optional: admin email for future campaign-request notifications
# ADMIN_EMAIL=you@example.com

DATABASE_URL="postgresql://user:password@localhost:5432/vybridge?schema=public"

STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Publishable (not secret) key — safe to expose client-side. Served to the
# browser via GET /api/config for the /slots checkout page's Stripe.js.
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Days after a deal's ends_at before the payout transfer is eligible to run.
# Buffer against disputes filed after the placement finished.
PAYOUT_BUFFER_DAYS=4

# Hours a creative can sit in pending_approval before it is auto-approved.
AUTO_APPROVE_HOURS=48

# Resend (resend.com) API key for deal-lifecycle notification emails
# (lib/email.js). If unset, emails are skipped and logged — never blocks
# the deal flow.
RESEND_API_KEY="re_..."

# Base URL used to build links in notification emails (webhook handlers and
# the payout cron run outside any HTTP request, so they can't read
# req.headers.host the way connect-http.js does). Set this to the real
# production domain on Railway.
APP_BASE_URL="http://localhost:3000"

# Cloudinary — creative image storage (lib/storage.js). Required for
# POST /api/deals to work at all; uploadCreative() throws loudly (never
# silently) if any of these three are missing.
CLOUDINARY_CLOUD_NAME="..."
CLOUDINARY_API_KEY="..."
CLOUDINARY_API_SECRET="..."

# /admin panel — gates access with a single shared password (not tied to
# any user account/role) and signs the resulting session cookie. Both are
# required; if either is missing, POST /api/admin/auth fails closed
# (500, "Admin panel is not configured") rather than silently accepting
# anything. Generate ADMIN_SESSION_SECRET with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_PASSWORD="change-me"
ADMIN_SESSION_SECRET="change-me-32-plus-random-characters"
