generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  publisher
  advertiser
  blogger
}

enum StripeOnboardingStatus {
  not_started
  pending
  complete
}

enum SiteStatus {
  active
  suspended
}

// Where Site.coverImageUrl currently came from — lets any future cover
// source (a publisher's own upload, an automatic screenshot, an
// AI-generated image, or a platform-provided default) populate the exact
// same field without the reader ever needing to know which one did it.
// "system" is reserved for a platform-provided cover (e.g. branded/
// category default artwork) — nothing assigns it yet.
enum CoverSource {
  placeholder
  manual
  automatic
  ai
  system
}

enum SlotStatus {
  draft
  active
  booked
  paused
}

// Status of the automatic Marketplace screenshot capture for a slot (see
// lib/slot-preview.js). "pending" covers both "not started yet" and
// "in progress" — there's no separate in-flight state since capture is
// fire-and-forget with no retry queue in Phase 1. Legacy slots default to
// pending (not failed) so the dashboard's manual "Regenerate preview"
// action gives them a real path to a screenshot rather than a permanent
// error state they never actually hit.
enum PreviewStatus {
  pending
  ready
  failed
}

// The viewport coordinate system a placement was captured against and
// should render against — not a physical device. Kept intentionally
// two-valued (no "all") to avoid ambiguous absolute-coordinate behavior;
// see Slot.viewportType below.
enum ViewportType {
  desktop
  mobile
}

enum DealStatus {
  created
  paid_escrow
  pending_approval
  approved
  live
  completed
  payout_released
  rejected
  disputed
  refunded

  // Blogger vertical: pending_blogger_approval -> blogger_accepted ->
  // blogger_published -> completed -> payout_released (completed and
  // payout_released above are shared with the slot vertical). declined is
  // this flow's terminal rejection, parallel to `rejected` above.
  pending_blogger_approval
  blogger_accepted
  blogger_published
  blogger_declined
}

enum CreativeStatus {
  submitted
  approved
  rejected
}

enum ChannelPlatform {
  instagram
  tiktok
  youtube
}

// What an advertiser is promoting in a blogger offer — drives which fields
// the offer form shows (see lib/blogger-deals.js).
enum OfferType {
  product
  website
  other
}

// The kind of post the advertiser wants the blogger to make.
enum AdFormat {
  reels
  stories
  post
}

enum SiteCategory {
  technology
  lifestyle
  automotive
  fashion
  food
  travel
  sports
  business
  entertainment
  education
  health
  news
  other
}

// Prisma enum value names can't start with a digit, so the "1k_10k"-style
// values the API/DB actually use are attached via @map — the Prisma-side
// names (range_1k_10k etc.) never leak past this schema file.
enum MonthlyVisitors {
  under_1k
  range_1k_10k    @map("1k_10k")
  range_10k_50k   @map("10k_50k")
  range_50k_200k  @map("50k_200k")
  range_200k_plus @map("200k_plus")
}

enum AudienceLanguage {
  english
  slovak
  ukrainian
  russian
  other
}

// The kind of thing a Listing advertises. website_banner/website_popup are
// the only values a Slot-sourced listing can get today (see
// lib/listings.js's mapSlotToListingType) — the rest are reserved for
// future sourceType values (blogger_channel etc.) so that adding a new kind
// of listing never needs a schema change here, just a new enum value.
enum ListingType {
  website_banner
  website_popup
  instagram_post
  tiktok_video
  youtube_integration
  podcast_ad
  newsletter_ad
}

// What kind of row sourceId points at. Not a Prisma relation — see the
// Listing model comment for why.
enum ListingSourceType {
  slot
  blogger_channel
}

enum ListingStatus {
  draft
  active
  paused
  archived
}

model User {
  id           String @id @default(uuid())
  email        String @unique
  passwordHash String @map("password_hash")
  role         Role
  name         String
  country      String
  locale       String @default("en")

  // Advertiser-only fields
  stripeCustomerId             String? @map("stripe_customer_id")
  lifetimeAdvertiserSpendCents BigInt  @default(0) @map("lifetime_advertiser_spend_cents")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  stripeAccount       StripeAccount?
  sites               Site[]
  slots               Slot[]               @relation("PublisherSlots")
  dealsAsAdvertiser   Deal[]               @relation("AdvertiserDeals")
  // Also holds blogger deals — a blogger is "PublisherDeals" in the same
  // sense a site publisher is: the party being paid out (see Deal.publisherId).
  dealsAsPublisher    Deal[]               @relation("PublisherDeals")
  bloggerChannels     BloggerChannel[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

model StripeAccount {
  id               String                 @id @default(uuid())
  userId           String                 @unique @map("user_id")
  user             User                   @relation(fields: [userId], references: [id])
  stripeAccountId  String                 @unique @map("stripe_account_id")
  onboardingStatus StripeOnboardingStatus @default(not_started) @map("onboarding_status")
  payoutsEnabled   Boolean                @default(false) @map("payouts_enabled")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("stripe_accounts")
}

model Site {
  id          String     @id @default(uuid())
  publisherId String     @map("publisher_id")
  publisher   User       @relation(fields: [publisherId], references: [id])
  domain      String
  siteKey     String     @unique @map("site_key")
  status      SiteStatus @default(active)

  // Public-facing identity for GET /sites/:slug — generated once from
  // domain at site-creation time (lib/users.js) and never regenerated, so
  // an already-shared public URL never breaks.
  slug               String      @unique
  // Cover image for the site's own public page and Marketplace card —
  // separate from any Listing's coverImageUrl (a site-level photo, not a
  // per-ad one). Deliberately source-agnostic: coverSource below records
  // provenance, but every reader of coverImageUrl (Marketplace catalog,
  // site page) only ever sees this one field, regardless of how it was set.
  coverImageUrl      String?     @map("cover_image_url")
  // Cloudinary's own asset identifier, captured straight from the upload
  // response (never parsed back out of coverImageUrl — that would be
  // fragile, and the URL already carries transformation segments that
  // aren't part of the id). Used only to delete the previous asset when a
  // cover is replaced or removed; never exposed outside lib/sites.js.
  coverImagePublicId String?     @map("cover_image_public_id")
  coverSource        CoverSource @default(placeholder) @map("cover_source")

  // Bumped on every GET /w.js whose Referer host matches this domain — the
  // dashboard's install checklist polls GET /api/sites/:site_key/verify,
  // which treats a hit within the last 24h as "code detected". Never set by
  // anything the publisher enters themselves, only by the server observing
  // a real request.
  lastScriptLoadAt DateTime? @map("last_script_load_at")

  // Audience info — entered by the publisher on the dashboard, shown to
  // advertisers in the /slots catalog so they can judge fit before booking.
  // All optional: a publisher who skips this just shows "No info provided"
  // on the catalog card rather than being blocked from listing slots.
  category         SiteCategory?
  monthlyVisitors  MonthlyVisitors?  @map("monthly_visitors")
  audienceCountry  String?           @map("audience_country")
  audienceLanguage AudienceLanguage? @map("audience_language")
  siteDescription  String?           @map("site_description")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  slots Slot[]

  @@index([domain])
  @@map("sites")
}

// A blogger's social account. One blogger user can have several (Instagram
// + TikTok + YouTube), each with its own price/category/follower count —
// an advertiser targets one specific channel per offer (see Deal.bloggerChannelId).
model BloggerChannel {
  id     String @id @default(uuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  platform          ChannelPlatform
  channelUrl        String          @map("channel_url")
  // Parsed from channelUrl at creation time (e.g. "@name") — best-effort
  // display convenience, never re-derived or trusted for anything else.
  channelHandle     String?         @map("channel_handle")
  followersCount    Int             @default(0) @map("followers_count")
  contentCategory   SiteCategory?   @map("content_category")
  pricePerPostCents Int             @map("price_per_post_cents")
  // If true, the catalog and offer form tell an advertiser they can propose
  // a different price on this channel instead of just paying the listed one.
  openToNegotiation Boolean         @default(true) @map("open_to_negotiation")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  deals Deal[]

  @@index([userId])
  @@map("blogger_channels")
}

model Slot {
  id          String @id @default(uuid())
  siteId      String @map("site_id")
  site        Site   @relation(fields: [siteId], references: [id])
  publisherId String @map("publisher_id")
  publisher   User   @relation("PublisherSlots", fields: [publisherId], references: [id])

  label            String
  // Public-facing identity for the Listing that wraps this slot (see the
  // Listing model) — generated once from label + site domain at finalize
  // time (lib/slots.js), never regenerated. Not a relation to Listing
  // itself — see Listing.sourceType/sourceId for why that link is
  // deliberately not a Prisma FK.
  slug             String  @unique
  // Legacy positioning: a CSS selector on the publisher's page, resolved
  // client-side by w.js. For a slot picked before drag-to-select existed,
  // this is the ad's own element. For a drag-to-select slot with no anchor
  // (below), it's an auto-generated placeholder, ignored in favor of
  // posX/posY/posWidth/posHeight. For a drag-to-select slot WITH a working
  // anchor, this field is reused to hold the anchor container's selector
  // (see anchorRelX/Y/Width/Height below) — disambiguated at render time by
  // hasFixedPosition()/the presence of anchor data, never ambiguous.
  domSelector      String  @map("dom_selector")
  fallbackAnchorId String? @map("fallback_anchor_id")
  format           String
  width            Int
  height           Int

  // Drag-to-select positioning: viewport-relative pixel coordinates from
  // the picker's mousedown/mouseup rectangle. Still captured for every
  // drag-to-select slot as the fallback (see anchorRelX/Y/Width/Height
  // below) — used verbatim, rendered via `position: fixed`, whenever no
  // anchor was captured or the anchor can no longer be found on the page.
  // Null for any slot picked before drag-to-select existed — those keep
  // rendering off domSelector above.
  posX      Int? @map("pos_x")
  posY      Int? @map("pos_y")
  posWidth  Int? @map("pos_width")
  posHeight Int? @map("pos_height")

  // Anchor-relative positioning (desktop only) — the selection expressed as
  // a fraction of the real DOM container it was drawn inside (domSelector
  // above holds that container's CSS selector), rather than as raw window
  // pixels. Responsive pages don't scale uniformly with window width (e.g.
  // a centered `max-width` container stops growing past its cap) — window-
  // relative pixels drift once the container's own box diverges from the
  // raw viewport, which relative-to-the-actual-container coordinates don't.
  // Null for legacy slots and for any slot whose anchor container wasn't
  // captured; w.js falls back to posX/Y/Width/Height in that case. Mobile
  // slots never populate these — mobile positioning is unchanged.
  anchorRelX      Float? @map("anchor_rel_x")
  anchorRelY      Float? @map("anchor_rel_y")
  anchorRelWidth  Float? @map("anchor_rel_width")
  anchorRelHeight Float? @map("anchor_rel_height")

  priceCents   Int    @map("price_cents")
  currency     String @default("eur")
  durationDays Int    @map("duration_days")

  status SlotStatus @default(draft)

  // Which viewport coordinate system posX/posY/posWidth/posHeight were
  // captured against — desktop and mobile placements are fully independent
  // Slot rows, never a single row covering both. Defaults to desktop since
  // every slot before this field existed was captured by the desktop-only
  // picker.
  viewportType ViewportType @default(desktop) @map("viewport_type")

  // Immutable capture metadata — the exact reference viewport this slot's
  // pos_x/pos_y/pos_width/pos_height were drawn against (1440x900 for
  // desktop, 400x800 for mobile — a neutral virtual coordinate system, not
  // tied to any specific real device). Set once by finalizeSlot() from the
  // validated viewportType and never written to again by anything, ever.
  // w.js's mobile scale formula divides by this value; changing it after
  // the fact would silently misposition an already-live ad without
  // changing pos_x/pos_y at all.
  pickerViewportWidth  Int @default(1440) @map("picker_viewport_width")
  pickerViewportHeight Int @default(900)  @map("picker_viewport_height")

  // Immutable — the version of the picker implementation that produced
  // this slot's coordinates (distinct from the reference viewport size
  // above — this is the capture ALGORITHM's version). Set once by
  // finalizeSlot(), never updated after.
  captureVersion Int @default(1) @map("capture_version")

  // The exact page createPickerSession() opened the picker against —
  // validated there (host must match site.domain) but not persisted until
  // now. Needed so the background screenshot capture (lib/slot-preview.js)
  // knows what to navigate to; without it, capture would have nothing but
  // the site's domain root, wrong for any slot picked on a non-homepage
  // page. Null for slots created before this field existed.
  pageUrl String? @map("page_url")

  // Marketplace preview screenshot (see lib/slot-preview.js) — a plain,
  // unmodified capture of the page with no highlight baked in; the
  // Marketplace draws the highlight itself via CSS using
  // posX/posY/posWidth/posHeight + pickerViewportWidth/pickerViewportHeight
  // above, so there's no separate previewRect field and no risk of the
  // highlight ever drifting from the slot's real position.
  previewImageUrl      String?       @map("preview_image_url")
  // Cloudinary's own asset id for previewImageUrl, captured from the
  // upload response — used only to delete the previous asset when a
  // preview is regenerated or the slot is deleted (same rationale as
  // Site.coverImagePublicId above).
  previewImagePublicId String?       @map("preview_image_public_id")
  previewStatus        PreviewStatus @default(pending) @map("preview_status")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  deals        Deal[]
  pickerTokens PickerToken[]

  @@map("slots")
}

// A publicly-addressable ad listing, independent of what it's actually
// backed by. sourceType/sourceId point at the origin row (a Slot today,
// eventually a BloggerChannel) — deliberately NOT a Prisma relation/FK.
// Unlike Deal.slotId/Deal.bloggerChannelId (two separate typed FK columns
// for its two known kinds), a Listing's possible source kinds are meant to
// keep growing (website placements, social posts, podcast reads, ...)
// without a new nullable FK column on this table every time one is added.
// Referential integrity for sourceId is therefore enforced in application
// code (see lib/listings.js's createListingForSlot, which re-checks the
// Slot exists immediately before writing), not by the database.
//
// @@unique([sourceType, sourceId]) is what actually guarantees "at most one
// Listing per source" — that constraint doesn't need a real FK to hold.
model Listing {
  id          String            @id @default(uuid())
  slug        String            @unique
  listingType ListingType       @map("listing_type")
  sourceType  ListingSourceType @map("source_type")
  sourceId    String            @map("source_id")

  title         String
  // Always null in Stage 1 — no editor exists yet to set these.
  description   String?
  coverImageUrl String? @map("cover_image_url")

  priceCents Int    @map("price_cents")
  currency   String @default("eur")

  // Created as `active` directly (see lib/slots.js's finalizeSlot) — there
  // is no draft/publish step in Stage 1. `paused`/`archived` are reserved
  // for a later stage's hide/unlist feature.
  status ListingStatus @default(draft)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([sourceType, sourceId])
  @@map("listings")
}

// One-time, short-lived tokens for the visual placement picker. The token
// itself IS the authorization for POST /api/slots/:id/selector — that route
// is called cross-origin from the publisher's own site (no session cookie
// available there), so possession of a valid, unused, unexpired token is
// the entire security model for that single write.
model PickerToken {
  id          String @id @default(uuid())
  slotId      String @map("slot_id")
  slot        Slot   @relation(fields: [slotId], references: [id])
  publisherId String @map("publisher_id")

  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("picker_tokens")
}

// One-time, short-lived tokens for the "forgot password" flow. Only ever
// one active (unused, unexpired) token per user — requesting a new one
// marks any previous token for the same user as used, so an old email
// link can never be replayed once a newer one has been sent.
model PasswordResetToken {
  id     String @id @default(uuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])
  token  String @unique

  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("password_reset_tokens")
}

model FeeTier {
  id                    String @id @default(uuid())
  name                  String
  minLifetimeSpendCents BigInt @map("min_lifetime_spend_cents")
  feeBps                Int    @map("fee_bps")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("fee_tiers")
}

model Deal {
  id String @id @default(uuid())

  // Exactly one of slotId/bloggerChannelId is set — slotId for the ad-slot
  // vertical, bloggerChannelId for the blogger vertical. Never both, never
  // neither; enforced in application code (lib/deals.js vs
  // lib/blogger-deals.js), not at the DB level.
  slotId String? @map("slot_id")
  slot   Slot?   @relation(fields: [slotId], references: [id])

  bloggerChannelId String?         @map("blogger_channel_id")
  bloggerChannel   BloggerChannel? @relation(fields: [bloggerChannelId], references: [id])

  // The party being paid out: the site publisher for a slot deal, or the
  // blogger for a blogger deal (see bloggerChannel.userId) — always set
  // either way, so payout-cron.js's releaseCompletedPayouts needs no branch.
  publisherId String @map("publisher_id")
  publisher   User   @relation("PublisherDeals", fields: [publisherId], references: [id])

  advertiserId String @map("advertiser_id")
  advertiser   User   @relation("AdvertiserDeals", fields: [advertiserId], references: [id])

  // Snapshots taken at booking time so later edits to slot price or fee
  // tiers never change the economics of an already-created deal. For a
  // blogger deal, slotPriceCents holds the agreed price per post instead.
  slotPriceCents    Int    @map("slot_price_cents")
  platformFeeBps    Int    @map("platform_fee_bps")
  platformFeeCents  Int    @map("platform_fee_cents")
  totalChargedCents Int    @map("total_charged_cents")
  currency          String @default("eur")
  // Not meaningful for a blogger deal (a post isn't "live" for N days) — 0 there.
  durationDays      Int    @map("duration_days")

  status        DealStatus @default(created)
  statusHistory Json       @default("[]") @map("status_history")

  // Set the moment the deal enters pending_approval — the auto-approve cron
  // filters on this to find deals that have sat unreviewed past the
  // AUTO_APPROVE_HOURS window.
  pendingApprovalAt DateTime? @map("pending_approval_at")

  // startsAt/endsAt/payoutEligibleAt are written together in the same
  // update as the approved->live transition (see lib/deals.js
  // transitionDealToLive) — never set independently.
  startsAt         DateTime? @map("starts_at")
  endsAt           DateTime? @map("ends_at")
  payoutEligibleAt DateTime? @map("payout_eligible_at")

  // Blogger vertical only: set when the blogger marks the deal as
  // published. publishedAt drives the 48h auto-confirm cron the same way
  // pendingApprovalAt drives auto-approve.
  publishedUrl String?   @map("published_url")
  publishedAt  DateTime? @map("published_at")

  // Blogger vertical only: what the advertiser is promoting and how,
  // collected by the offer-type-specific form in bloggers/bloggers.js
  // instead of the old ready_file/brief Creative flow. clickUrl lives here
  // (not on Creative) because a blogger deal never creates a Creative row.
  offerType            OfferType? @map("offer_type")
  productName          String?    @map("product_name")
  productImageUrl      String?    @map("product_image_url")
  websiteUrl           String?    @map("website_url")
  adFormat             AdFormat?  @map("ad_format")
  contentDescription   String?    @map("content_description")
  sendPhysicalProduct  Boolean    @default(false) @map("send_physical_product")
  deliveryInstructions String?    @map("delivery_instructions")
  clickUrl             String?    @map("click_url")

  stripePaymentIntentId String? @unique @map("stripe_payment_intent_id")
  stripeChargeId        String? @map("stripe_charge_id")
  stripeTransferId      String? @map("stripe_transfer_id")
  stripeRefundId        String? @map("stripe_refund_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  creatives Creative[]
  clicks    Click[]

  @@index([status])
  @@index([slotId])
  @@index([bloggerChannelId])
  @@index([status, pendingApprovalAt])
  @@index([status, endsAt])
  @@index([status, payoutEligibleAt])
  @@index([status, publishedAt])
  @@map("deals")
}

model Creative {
  id     String @id @default(uuid())
  dealId String @map("deal_id")
  deal   Deal   @relation(fields: [dealId], references: [id])

  // Slot-ad creatives only — a blogger offer no longer creates a Creative
  // row at all (see Deal's own offerType/productName/etc. fields), so
  // every field here is required again like before the blogger vertical
  // temporarily widened this model.
  fileUrl       String @map("file_url")
  clickUrl      String @map("click_url")
  width         Int
  height        Int
  mimeType      String @map("mime_type")
  fileSizeBytes Int    @map("file_size_bytes")

  status          CreativeStatus @default(submitted)
  rejectionReason String?        @map("rejection_reason")

  submittedAt DateTime  @default(now()) @map("submitted_at")
  reviewedAt  DateTime? @map("reviewed_at")

  clicks Click[]

  @@map("creatives")
}

// One row per (rate-limit-eligible) ad click. Deliberately keyed off the
// deal, not the creative, so click history survives if a rejected creative
// is ever resubmitted under the same deal.
model Click {
  id         String    @id @default(uuid())
  dealId     String    @map("deal_id")
  deal       Deal      @relation(fields: [dealId], references: [id])
  creativeId String?   @map("creative_id")
  creative   Creative? @relation(fields: [creativeId], references: [id])

  ip        String
  userAgent String? @map("user_agent")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([dealId, ip, createdAt])
  @@map("clicks")
}

// Stripe webhook idempotency ledger — every processed event id is recorded
// here before its side effects are applied, so a redelivered event is a no-op.
model StripeEvent {
  id          String   @id
  type        String
  processedAt DateTime @default(now()) @map("processed_at")

  @@map("stripe_events")
}
