    "migrate:deploy": "prisma migrate deploy",
    "seed": "node --env-file=.env prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "stripe": "^22.3.0"
  },
  "devDependencies": {
    "prisma": "6.19.3"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
